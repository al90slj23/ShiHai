{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shihai.local/schemas/event.schema.json",
  "title": "ShiHai Event",
  "type": "object",
  "required": [
    "id",
    "time_start",
    "type",
    "source_type",
    "summary",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "time_start": {
      "type": "string"
    },
    "time_end": {
      "type": [
        "string",
        "null"
      ]
    },
    "type": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "content_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "importance": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "privacy": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "created_by": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}