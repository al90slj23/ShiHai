{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShiHai Relation",
  "type": "object",
  "required": [
    "subject",
    "predicate",
    "object",
    "confidence",
    "created_at"
  ],
  "properties": {
    "subject": {
      "type": "string"
    },
    "predicate": {
      "type": "string"
    },
    "object": {
      "type": "string"
    },
    "valid_from": {
      "type": [
        "string",
        "null"
      ]
    },
    "valid_to": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_events": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_by": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}